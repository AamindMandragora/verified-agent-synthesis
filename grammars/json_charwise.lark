// JSON Grammar for Constrained Decoding with Character-Level Strings
// This version allows incremental string building (no ESCAPED_STRING terminal)

start: value

?value: object
      | array
      | string
      | number
      | "true"   -> true
      | "false"  -> false
      | "null"   -> null

object: "{" [pair ("," pair)*] "}"
pair: string ":" value

array: "[" [value ("," value)*] "]"

// Character-level string definition (allows partial string tokens)
string: DQUOTE string_inner DQUOTE
string_inner: (STRCHAR | STRESCAPE)*

// Double quote terminal
DQUOTE: "\""

// Any printable ASCII except quote and backslash
STRCHAR: /[ !#-\[\]-~]/

// Escape sequences  
STRESCAPE: /\\[\"\\\/bfnrt]/ | /\\u[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F]/

number: SIGNED_NUMBER

%import common.SIGNED_NUMBER
%import common.WS
%ignore WS
